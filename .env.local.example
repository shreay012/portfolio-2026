# Environment Variables — copy to .env.local and fill in values

# ── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/shreay-portfolio

# ── Email (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Use a Gmail App Password (not your main password)
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=shreay@yourdomain.com

# ── reCAPTCHA v3 (optional — remove usage if not needed) ────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://shreaygoyal.com

# ── CMS ──────────────────────────────────────────────────────────────────────
# Required for /cms and /api/cms authenticated access.
CMS_ADMIN_USERNAME=admin
CMS_ADMIN_PASSWORD=change-this-to-a-strong-password
CMS_SESSION_SECRET=change-this-to-a-long-random-secret
